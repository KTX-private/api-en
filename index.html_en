    </span><span class="nl">"discountForFee"</span><span class="p">:</span><span class="s2">"1"</span><span class="w"> </span><span class="err">//</span><span class="w"> </span><span class="err">Fee</span><span class="w"> </span><span class="err">discount</span><span class="w"> </span><span class="err">rate</span><span class="w"> </span><span class="p">[</span><span class="mi">0</span><span class="err">:</span><span class="w"> </span><span class="err">Unavailable</span><span class="w"> </span><span class="err">|</span><span class="w"> </span><span class="mf">0.5</span><span class="err">:</span><span class="w"> </span><span class="mi">50</span><span class="err">%</span><span class="w"> </span><span class="err">|</span><span class="w"> </span><span class="mi">1</span><span class="err">:</span><span class="w"> </span><span class="mi">100</span><span class="err">%</span><span class="p">]</span><span class="w">
